{
  "permissions": {
    "allow": [
      "Bash(python test_gesture_control.py)",
      "Bash(python -m pytest *)",
      "Bash(pytest *)",
      "Bash(python -m py_compile *)",
      "Bash(python -c *)"
    ]
  },
  "env": {
    "PERF_MONITORING": "true",
    "PREFER_EDGE_AI": "false"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; [[ \"$f\" =~ \\.py$ ]] && [[ ! \"$f\" =~ test_ ]] && python -m pytest test_gesture_control.py -q 2>&1 | tail -5 || true; }",
            "timeout": 60,
            "statusMessage": "Running test suite validation..."
          }
        ]
      }
    ],
    "PreToolUse": []
  }
}
